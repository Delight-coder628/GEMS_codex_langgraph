# Required company MLLM settings. Keep real credentials out of Git.
MLLM_BASE_URL=
MLLM_API_KEY=
MLLM_MODEL=

# Agent-to-generator HTTP endpoint.
GENERATOR_URL=http://127.0.0.1:8001/generate

# Optional internal Qwen-Image-Edit endpoint. Keep editor.enabled=false until ready.
EDITOR_URL=http://127.0.0.1:8003/edit

# Optional internal OCR sidecar endpoint when ocr.backend=http.
OCR_URL=http://127.0.0.1:8002/ocr

# Absolute path to the downloaded ModelScope Z-Image-Turbo snapshot.
ZIMAGE_MODEL_PATH=

# One or two physical NPU IDs, for example: 0 or 0,1
ASCEND_RT_VISIBLE_DEVICES=
